# Copy this file to .env and fill in your local values.
# Do not commit .env.

PYTHONIOENCODING=utf-8

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b-instruct-q4_0

# Server
HOST=0.0.0.0
PORT=8765

# Whisper
WHISPER_MODEL=small.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16

# Home Assistant — Mode 1: Online Intelligent HA Mode
HOME_ASSISTANT_URL=http://192.168.XXX.XXX:8123
HOME_ASSISTANT_TOKEN=paste_your_long_lived_access_token_here
HOME_ASSISTANT_TIMEOUT_SEC=5.0

# Existing Home Assistant MQTT switch entity IDs
HA_ENTITY_TV=switch.your_tv_entity    
HA_ENTITY_SOUNDBAR=switch.your_soundbar_entity  # Entity ID's of 4 Devices you create in Smart-Switch-Board
HA_ENTITY_SUBWOOFER=switch.your_subwoofer_entity
HA_ENTITY_REAR=switch.your_rear_speakers_entity

# ESP8266 Home IP fallback — Mode 2: Online Intelligent Relay Mode
# Used when Zyra Server is alive but Home Assistant is unavailable.
RELAY_HOME_BASE_URLS=http://192.168.XXX.XXX # Your ESP8266 Smart-Switch-board Home IP
RELAY_HTTP_TIMEOUT_SEC=2.5

# Future API keys
# GROQ_API_KEY=your_key_here
# TAVILY_API_KEY=your_key_here