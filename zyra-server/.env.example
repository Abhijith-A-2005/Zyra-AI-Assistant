# Copy this file to .env and fill in your values
PYTHONIOENCODING=utf-8

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Server
HOST=0.0.0.0
PORT=8765
# Smart home relay board
# Use your ESP8266 home Wi-Fi IP first.
# Direct AP fallback is http://192.168.4.1 when connected to ESP-REMOTE-DIRECT.
SMART_HOME_BASE_URLS=http://192.168.31.156
SMART_HOME_TIMEOUT_SEC=2.0

# Future API keys (add when needed)
# GROQ_API_KEY=your_key_here
# TAVILY_API_KEY=your_key_here